# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Tavily (optional, for search/intel tools)
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google APIs
# Path to your Google Service Account JSON file (e.g. key.json)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# The ID of the Google Calendar to use (e.g. your_email@gmail.com)
GOOGLE_CALENDAR_ID=primary

# Database
DATABASE_URL=sqlite+aiosqlite:///./personal_ai.db

# Gmail/Email (SMTP/IMAP) - use a Gmail App Password (16 chars)
GOOGLE_EMAIL=your_email@gmail.com
GOOGLE_TEMP_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# App
SECRET_KEY=your-secret-key-here
DEBUG=false
LOG_LEVEL=INFO

# Scheduler
DAILY_BRIEFING_HOUR=7
DAILY_BRIEFING_MINUTE=30
EVENING_CHECKIN_HOUR=21
EVENING_CHECKIN_MINUTE=0
REMINDER_LEAD_MINUTES=0
